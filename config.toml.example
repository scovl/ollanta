# Minimal local configuration for Ollanta.
# Copy this file to config.toml when you want repeatable local runs:
#   cp config.toml.example config.toml
#
# CLI flags and OLLANTA_* environment variables still override this file.

[scanner]
project_dir = "."
project_key = "ollanta"
sources = ["./..."]
exclusions = [".git/**", ".ollanta/**", "**/node_modules/**"]
format = "all" # summary, json, sarif, all
local_ui = true
bind = "127.0.0.1"
port = 7777

# Uncomment these when this scanner should push to a centralized server.
# server_url = "http://localhost:8080"
# server_token = "ollanta-dev-scanner-token"
server_wait = false
server_wait_timeout = "10m"
server_wait_poll = "2s"

# Quality Profiles control which rules run. Keep auto for first use:
# local profile file when configured, server profiles when a server URL is set,
# otherwise built-in defaults.
profile_source = "auto" # auto, local, server, builtin
profile_file = ""
profile_strict = false
profile_fetch_timeout = "10s"

# Optional test and mutation evidence. Disabled by default so a first scan never
# executes repository commands. See docs/test-signals.md for full examples.
[tests]
enabled = false

[mutations]
enabled = false

# Server settings are needed only when running ollantaweb or worker binaries
# directly. Docker Compose supplies these values through environment variables.
[server]
addr = ":8080"
admin_addr = ":9090"
log_level = "info"
jwt_secret = "ollanta-dev-jwt-secret-change-me"
cors_allowed_origins = ["http://localhost:8080"]
auto_migrate = true
scanner_token = "ollanta-dev-scanner-token"

[database]
host = "localhost"
port = 5432
name = "ollanta"
user = "ollanta"
password = "ollanta_dev"
sslmode = "disable"
pool_max_conns = 25
pool_min_conns = 5

[search]
backend = "zincsearch" # zincsearch or postgres
url = "http://localhost:4080"
user = "admin"
password = "ollanta_dev"
